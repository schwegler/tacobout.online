{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#fafafa",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#0f0f0f",
					"name": "Contrast"
				},
				{
					"slug": "accent",
					"color": "#8b5cf6",
					"name": "Accent"
				},
				{
					"slug": "accent-2",
					"color": "#d946ef",
					"name": "Accent Secondary"
				},
				{
					"slug": "muted",
					"color": "#71717a",
					"name": "Muted"
				},
				{
					"slug": "surface",
					"color": "#f4f4f5",
					"name": "Surface"
				},
				{
					"slug": "surface-2",
					"color": "#e4e4e7",
					"name": "Surface Alt"
				}
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"spacing": {
			"units": ["%", "px", "em", "rem", "vh", "vw"],
			"blockGap": true,
			"margin": true,
			"padding": true,
			"spacingSizes": [
				{ "size": "0.5rem", "slug": "10", "name": "1" },
				{ "size": "1rem", "slug": "20", "name": "2" },
				{ "size": "1.5rem", "slug": "30", "name": "3" },
				{ "size": "2rem", "slug": "40", "name": "4" },
				{ "size": "3rem", "slug": "50", "name": "5" },
				{ "size": "4rem", "slug": "60", "name": "6" },
				{ "size": "6rem", "slug": "70", "name": "7" },
				{ "size": "8rem", "slug": "80", "name": "8" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Space Grotesk', system-ui, sans-serif",
					"slug": "heading",
					"name": "Space Grotesk"
				},
				{
					"fontFamily": "'Instrument Sans', system-ui, -apple-system, sans-serif",
					"slug": "body",
					"name": "Instrument Sans"
				},
				{
					"fontFamily": "'SF Mono', 'Fira Code', 'Fira Mono', monospace",
					"slug": "mono",
					"name": "Monospace"
				}
			],
			"fontSizes": [
				{ "size": "0.75rem", "slug": "x-small", "name": "XS" },
				{ "size": "0.875rem", "slug": "small", "name": "Small" },
				{ "size": "1rem", "slug": "medium", "name": "Medium" },
				{ "size": "1.25rem", "slug": "large", "name": "Large" },
				{ "size": "1.75rem", "slug": "x-large", "name": "XL" },
				{ "size": "clamp(2rem, 4vw, 3.5rem)", "slug": "xx-large", "name": "2XL" },
				{ "size": "clamp(2.5rem, 5vw, 5rem)", "slug": "huge", "name": "Huge" }
			]
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "post-meta",
			"title": "Post Meta",
			"area": "uncategorized"
		},
		{
			"name": "comments",
			"title": "Comments",
			"area": "uncategorized"
		}
	],
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"padding": {
				"left": "var(--wp--preset--spacing--40)",
				"right": "var(--wp--preset--spacing--40)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-2)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "700",
					"lineHeight": "1.05",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "600",
					"lineHeight": "1.25",
					"letterSpacing": "-0.01em"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "100px"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent)"
					}
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"letterSpacing": "-0.02em"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							}
						}
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--large)",
					"letterSpacing": "-0.02em",
					"textTransform": "none"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--muted)"
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)",
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--surface-2)"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--accent)",
						"width": "4px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontStyle": "normal"
				}
			}
		}
	}
}
